<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.EazpireWear" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/wear_bg</item>
        <item name="android:statusBarColor">@color/wear_bg</item>
        <item name="android:navigationBarColor">@color/wear_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <style name="Theme.EazpireWear.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/wear_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.EazpireWear</item>
    </style>
</resources>
